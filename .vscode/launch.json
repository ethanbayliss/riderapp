  "version": "0.2.0",
  "configurations": [

    {
      "name": "riderapp Android Emulator (debug)",
      "request": "launch",
      "type": "dart",
      "deviceId": "emulator-5554",
      "toolArgs": ["--dart-define-from-file=.env.json"]
    },
    {
      "name": "riderapp Android Wireless (debug)",
      "request": "launch",
      "type": "dart",
      "deviceId": "adb-56040DLAQ00498-CYPRw0._adb-tls-connect._tcp",
      "toolArgs": ["--dart-define-from-file=.env.json"]
    },
    {
      "name": "riderapp Android Emulator (profile mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile",
      "deviceId": "emulator-5554",
      "toolArgs": ["--dart-define-from-file=.env.json"]
    },
    {
      "name": "riderapp Android Wireless (profile mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile",
      "deviceId": "adb-56040DLAQ00498-CYPRw0._adb-tls-connect._tcp",
      "toolArgs": ["--dart-define-from-file=.env.json"]
    },
    {
      "name": "riderapp Android Emulator (release mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "deviceId": "emulator-5554",
      "toolArgs": ["--dart-define-from-file=.env.json"]
    },
    {
      "name": "riderapp (web)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "toolArgs": ["--web-port", "8080", "--dart-define-from-file=.env.json"],
      "env": {
        "CHROME_EXECUTABLE": "/snap/chromium/3375/usr/lib/chromium-browser/chrome"
      }
    }
  ]
}
