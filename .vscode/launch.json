{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [

    {
      "name": "riderapp Android (debug)",
      "request": "launch",
      "type": "dart",
      "deviceId": "emulator-5554",
      "toolArgs": ["--dart-define-from-file=.env.json"]
    },
    {
      "name": "riderapp (web)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "toolArgs": ["--web-port", "8080", "--dart-define-from-file=.env.json"],
      "env": {
        "CHROME_EXECUTABLE": "/snap/chromium/3375/usr/lib/chromium-browser/chrome"
      }
    },
    {
      "name": "riderapp (profile mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile",
      "toolArgs": ["--dart-define-from-file=.env.json"]
    },
    {
      "name": "riderapp (release mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "toolArgs": ["--dart-define-from-file=.env.json"]
    }
  ]
}
